{
  "name": "@oblivion/contracts",
  "version": "1.0.0",
  "description": "Midnight smart contracts for Oblivion Protocol",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "compile": "compact compile src/DataCommitment.compact managed/DataCommitment && compact compile src/ZKDeletionVerifier.compact managed/ZKDeletionVerifier",
    "build": "npm run compile && tsc",
    "deploy": "tsx scripts/deployment-script/deploy.ts",
    "deploy:new-wallet": "MIDNIGHT_WALLET_MODE=new tsx scripts/deploy-preprod.ts",
    "deploy:preprod": "tsx scripts/deploy-preprod.ts",
    "start-local-midnight": "bash ../start-local-midnight.sh",
    "stop-local-midnight": "docker compose -f ../midnight-local-compose.yml down",
    "check-balance": "ts-node scripts/check-balance.ts",
    "start-proof-server": "/usr/local/bin/docker run -p 6300:6300 midnightntwrk/proof-server:8.0.3 midnight-proof-server -v",
    "test": "jest",
    "test:proof-server": "ts-node scripts/test-proof-server.ts",
    "test:interaction": "tsc && node dist/scripts/test-contract-interaction.js"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/ledger": "^4.0.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.4",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-types": "4.0.4",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.1.0",
    "@midnight-ntwrk/zswap": "^4.0.0",
    "dotenv": "^17.4.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
