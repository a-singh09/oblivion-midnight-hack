{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "scripts/deployment-script",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "scripts/deployment-script/deploy.ts",
    "scripts/deployment-script/utils.ts",
    // "scripts/check-balance.ts",
    // "scripts/deploy-preprod.ts",
    // "scripts/test-proof-server.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "managed"
  ]
}
